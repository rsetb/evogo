{
  "name": "@evoapi/evonexus-ui",
  "version": "0.1.1",
  "description": "EvoNexus plugin UI primitives — Button, Form, Table, Modal, schema-driven CRUD with Ajv",
  "keywords": ["evonexus", "plugin", "react", "ui", "schema-form"],
  "license": "MIT",
  "author": "Evolution Foundation <contato@evolutionfoundation.com.br>",
  "homepage": "https://evonexus.evolutionfoundation.com.br",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/EvolutionAPI/evo-nexus.git",
    "directory": "dashboard/packages/ui"
  },
  "type": "module",
  "files": ["dist/", "src/tokens.css", "tailwind-preset.js", "README.md", "LICENSE"],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./tokens.css": "./src/tokens.css",
    "./tailwind-preset": "./tailwind-preset.js"
  },
  "scripts": {
    "build": "vite build && tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.build.json --noEmit",
    "prepublishOnly": "npm run build"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "lucide-react": "^1.7.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.1",
    "typescript": "~5.9.0",
    "vite": "^8.0.0"
  }
}
